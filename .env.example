APP_NAME=BarqawiCars
APP_ENV=local          # production : production
APP_KEY=
APP_DEBUG=false        # local dev : true  |  JAMAIS true en production (expose stack traces + config)
APP_URL=http://localhost  # production : https://barqawi-cars.de

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# Herd (local without Docker): DB_CONNECTION=sqlite
# Docker local:                DB_CONNECTION=mysql  +  values below
# Docker production:           DB_CONNECTION=mysql  +  strong passwords
DB_CONNECTION=sqlite
# DB_HOST=mysql           # Docker service name — use 127.0.0.1 for Herd
# DB_PORT=3306
# DB_DATABASE=barqawicars
# DB_USERNAME=laravel
# DB_PASSWORD=secret
# DB_ROOT_PASSWORD=rootsecret  # used by docker-compose.prod.yml healthcheck

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true  # local dev : false (pas de HTTPS en local)  |  true obligatoire en production

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file        # production : file | redis — éviter database
# CACHE_STORE=database  # local dev uniquement
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1  # Docker: use "redis" (service name)
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log         # Docker dev: smtp  |  production: your SMTP provider
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1   # Docker dev: mailpit  |  production: SMTP host
MAIL_PORT=2525        # Docker dev: 1025  |  production: 587 (TLS)
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@barqawi-cars.de"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── SEO ───────────────────────────────────────────────────────────────────────
SEO_LASTMOD=2026-06-09

# ── Analytics ─────────────────────────────────────────────────────────────────
# Laisser vide en local — le script n'est injecté qu'en production (APP_ENV=production)
GOOGLE_ANALYTICS_ID=
